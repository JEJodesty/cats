# --- IDE & tooling ---
*.egg-info
.idea/
.vscode/
.cursor/
__marimo__/
__marimo__/**
*.pyc
.ipynb_checkpoints
.pytest_cache
.venv
.obsidian
.env

# --- Terraform (local state & cache; lock file is committed) ---
**/.terraform/
**/.terraform-data/
**/terraform.tfstate
**/terraform.tfstate.*
!**/.terraform.lock.hcl

# --- data/ ---
# Ephemeral runtime trees
data/cache/
data/jobs/
data/output/
data/deprecated/
data/testing/

# data/input — downloaded/written at runtime
data/input/order.json
data/input/__pycache__/
data/input/function/__pycache__/
data/input/.terraform/

# data/input/structure — runtime artifacts
# Committed: main.tf, ipfs_transport_compose.yaml, ipfs_connect_peers.sh, .terraform.lock.hcl
data/input/structure/.applied-structure.cid
data/input/structure/.host-ipfs-daemon.pid
data/input/structure/.host-ipfs-daemon.log

# local artifacts
local_artifacts/